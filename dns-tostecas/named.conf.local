zone "tostecas.diana.com" {
    type master;
    file "/etc/bind/db.tostecas.diana.com";
    allow-transfer { 172.30.0.2; };
    also-notify { 172.30.0.2; };
};

zone "nachos.diana.com" {
    type slave;
    masters { 172.30.0.2; };
    file "/var/cache/bind/db.nachos.diana.com";
};

zone "0.30.172.in-addr.arpa" {
    type slave;
    masters { 172.30.0.2; };
    file "/var/cache/bind/db.172.30.0";
};